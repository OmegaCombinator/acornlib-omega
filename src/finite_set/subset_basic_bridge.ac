from finite_set.base import FiniteSet, fs_union, fs_intersection,
    finite_set_subset_refl, finite_set_subset_trans,
    finite_set_union_subset_eq, finite_set_subset_intersection_eq

/// A finite set is contained in its union with another finite set on the right.
theorem finite_set_subset_union_left[T](a: FiniteSet[T], b: FiniteSet[T]) {
    a.subset_eq(fs_union(a, b))
} by {
    finite_set_subset_refl(fs_union(a, b))
    fs_union(a, b).subset_eq(fs_union(a, b))
    finite_set_union_subset_eq(a, b, fs_union(a, b))
    fs_union(a, b).subset_eq(fs_union(a, b)) =
        (a.subset_eq(fs_union(a, b)) and b.subset_eq(fs_union(a, b)))
    a.subset_eq(fs_union(a, b)) and b.subset_eq(fs_union(a, b))
    a.subset_eq(fs_union(a, b))
}

/// A finite set is contained in its union with another finite set on the left.
theorem finite_set_subset_union_right[T](a: FiniteSet[T], b: FiniteSet[T]) {
    b.subset_eq(fs_union(a, b))
} by {
    finite_set_subset_refl(fs_union(a, b))
    fs_union(a, b).subset_eq(fs_union(a, b))
    finite_set_union_subset_eq(a, b, fs_union(a, b))
    fs_union(a, b).subset_eq(fs_union(a, b)) =
        (a.subset_eq(fs_union(a, b)) and b.subset_eq(fs_union(a, b)))
    a.subset_eq(fs_union(a, b)) and b.subset_eq(fs_union(a, b))
    b.subset_eq(fs_union(a, b))
}

/// The intersection of two finite sets is contained in its left factor.
theorem finite_set_intersection_subset_left[T](a: FiniteSet[T], b: FiniteSet[T]) {
    fs_intersection(a, b).subset_eq(a)
} by {
    finite_set_subset_refl(fs_intersection(a, b))
    fs_intersection(a, b).subset_eq(fs_intersection(a, b))
    finite_set_subset_intersection_eq(a, b, fs_intersection(a, b))
    fs_intersection(a, b).subset_eq(fs_intersection(a, b)) =
        (fs_intersection(a, b).subset_eq(a) and fs_intersection(a, b).subset_eq(b))
    fs_intersection(a, b).subset_eq(a) and fs_intersection(a, b).subset_eq(b)
    fs_intersection(a, b).subset_eq(a)
}

/// The intersection of two finite sets is contained in its right factor.
theorem finite_set_intersection_subset_right[T](a: FiniteSet[T], b: FiniteSet[T]) {
    fs_intersection(a, b).subset_eq(b)
} by {
    finite_set_subset_refl(fs_intersection(a, b))
    fs_intersection(a, b).subset_eq(fs_intersection(a, b))
    finite_set_subset_intersection_eq(a, b, fs_intersection(a, b))
    fs_intersection(a, b).subset_eq(fs_intersection(a, b)) =
        (fs_intersection(a, b).subset_eq(a) and fs_intersection(a, b).subset_eq(b))
    fs_intersection(a, b).subset_eq(a) and fs_intersection(a, b).subset_eq(b)
    fs_intersection(a, b).subset_eq(b)
}

/// Finite-set union is monotone in its left argument.
theorem finite_set_union_monotone[T](a: FiniteSet[T], b: FiniteSet[T], c: FiniteSet[T]) {
    a.subset_eq(b) implies fs_union(a, c).subset_eq(fs_union(b, c))
} by {
    if a.subset_eq(b) {
        finite_set_subset_union_left(b, c)
        b.subset_eq(fs_union(b, c))
        finite_set_subset_trans(a, b, fs_union(b, c))
        a.subset_eq(fs_union(b, c))
        finite_set_subset_union_right(b, c)
        c.subset_eq(fs_union(b, c))
        a.subset_eq(fs_union(b, c)) and c.subset_eq(fs_union(b, c))
        finite_set_union_subset_eq(a, c, fs_union(b, c))
        fs_union(a, c).subset_eq(fs_union(b, c)) =
            (a.subset_eq(fs_union(b, c)) and c.subset_eq(fs_union(b, c)))
        fs_union(a, c).subset_eq(fs_union(b, c))
    }
}

/// Finite-set intersection is monotone in its left argument.
theorem finite_set_intersection_monotone[T](a: FiniteSet[T], b: FiniteSet[T], c: FiniteSet[T]) {
    a.subset_eq(b) implies fs_intersection(a, c).subset_eq(fs_intersection(b, c))
} by {
    if a.subset_eq(b) {
        finite_set_intersection_subset_left(a, c)
        fs_intersection(a, c).subset_eq(a)
        finite_set_subset_trans(fs_intersection(a, c), a, b)
        fs_intersection(a, c).subset_eq(b)
        finite_set_intersection_subset_right(a, c)
        fs_intersection(a, c).subset_eq(c)
        fs_intersection(a, c).subset_eq(b) and fs_intersection(a, c).subset_eq(c)
        finite_set_subset_intersection_eq(b, c, fs_intersection(a, c))
        fs_intersection(a, c).subset_eq(fs_intersection(b, c)) =
            (fs_intersection(a, c).subset_eq(b) and fs_intersection(a, c).subset_eq(c))
        fs_intersection(a, c).subset_eq(fs_intersection(b, c))
    }
}
