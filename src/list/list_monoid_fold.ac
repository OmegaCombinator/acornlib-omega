from list.list_base import List
from monoid import Monoid
from functions import function_extensionality

/// Evaluates a list of generators in an arbitrary (possibly noncommutative) monoid.
define list_monoid_fold[T, A: Monoid](items: List[T], f: T -> A) -> A {
    match items {
        List.nil {
            A.1
        }
        List.cons(head, tail) {
            f(head) * list_monoid_fold(tail, f)
        }
    }
}

/// The evaluator sends the empty list to the monoid identity.
theorem list_monoid_fold_nil[T, A: Monoid](f: T -> A) {
    list_monoid_fold(List.nil[T], f) = A.1
}

/// The evaluator sends a cons list to the head value times the tail value.
theorem list_monoid_fold_cons[T, A: Monoid](head: T, tail: List[T], f: T -> A) {
    list_monoid_fold(List.cons(head, tail), f) = f(head) * list_monoid_fold(tail, f)
}

/// The evaluator sends list concatenation to monoid multiplication.
theorem list_monoid_fold_append[T, A: Monoid](left: List[T], right: List[T], f: T -> A) {
    list_monoid_fold(left + right, f) = list_monoid_fold(left, f) * list_monoid_fold(right, f)
} by {
    define p(l: List[T]) -> Bool {
        list_monoid_fold(l + right, f) = list_monoid_fold(l, f) * list_monoid_fold(right, f)
    }
    List.nil[T] + right = right
    list_monoid_fold(List.nil[T], f) = A.1
    A.1 * list_monoid_fold(right, f) = list_monoid_fold(right, f)
    p(List.nil[T])
    forall(head: T, tail: List[T]) {
        if p(tail) {
            List.cons(head, tail) + right = List.cons(head, tail + right)
            list_monoid_fold(List.cons(head, tail + right), f) =
                f(head) * list_monoid_fold(tail + right, f)
            list_monoid_fold(tail + right, f) =
                list_monoid_fold(tail, f) * list_monoid_fold(right, f)
            list_monoid_fold(List.cons(head, tail + right), f) =
                f(head) * (list_monoid_fold(tail, f) * list_monoid_fold(right, f))
            f(head) * (list_monoid_fold(tail, f) * list_monoid_fold(right, f)) =
                (f(head) * list_monoid_fold(tail, f)) * list_monoid_fold(right, f)
            list_monoid_fold(List.cons(head, tail), f) = f(head) * list_monoid_fold(tail, f)
            list_monoid_fold(List.cons(head, tail) + right, f) =
                list_monoid_fold(List.cons(head, tail), f) * list_monoid_fold(right, f)
            p(List.cons(head, tail))
        }
    }
    List.induction(function(l: List[T]) { p(l) })
    forall(l: List[T]) { p(l) }
    p(left)
}

/// The evaluator sends a singleton list to the value of its generator.
theorem list_monoid_fold_singleton[T, A: Monoid](x: T, f: T -> A) {
    list_monoid_fold(List.singleton(x), f) = f(x)
} by {
    List.singleton(x) = List.cons(x, List.nil[T])
    list_monoid_fold(List.cons(x, List.nil[T]), f) = f(x) * list_monoid_fold(List.nil[T], f)
    list_monoid_fold(List.nil[T], f) = A.1
    f(x) * A.1 = f(x)
    list_monoid_fold(List.singleton(x), f) = f(x)
}

/// The evaluator as a function from lists to the target monoid.
define list_monoid_fold_fn[T, A: Monoid](f: T -> A) -> (List[T] -> A) {
    function(items: List[T]) {
        list_monoid_fold(items, f)
    }
}

/// A function satisfying the same nil and cons equations agrees with the evaluator at each list.
theorem list_monoid_fold_unique_at[T, A: Monoid](h: List[T] -> A, f: T -> A, xs: List[T]) {
    h(List.nil[T]) = A.1 and
    (forall(x: T, ys: List[T]) { h(List.cons(x, ys)) = f(x) * h(ys) })
    implies h(xs) = list_monoid_fold(xs, f)
} by {
    if h(List.nil[T]) = A.1 and
        forall(x: T, ys: List[T]) { h(List.cons(x, ys)) = f(x) * h(ys) } {
        define p(l: List[T]) -> Bool {
            h(l) = list_monoid_fold(l, f)
        }
        h(List.nil[T]) = A.1
        list_monoid_fold(List.nil[T], f) = A.1
        p(List.nil[T])
        forall(head: T, tail: List[T]) {
            if p(tail) {
                h(List.cons(head, tail)) = f(head) * h(tail)
                h(tail) = list_monoid_fold(tail, f)
                f(head) * h(tail) = f(head) * list_monoid_fold(tail, f)
                list_monoid_fold(List.cons(head, tail), f) = f(head) * list_monoid_fold(tail, f)
                h(List.cons(head, tail)) = list_monoid_fold(List.cons(head, tail), f)
                p(List.cons(head, tail))
            }
        }
        List.induction(function(l: List[T]) { p(l) })
        forall(l: List[T]) { p(l) }
        p(xs)
        h(xs) = list_monoid_fold(xs, f)
    }
}

/// A function satisfying the same nil and cons equations is extensionally the evaluator.
theorem list_monoid_fold_unique[T, A: Monoid](h: List[T] -> A, f: T -> A) {
    h(List.nil[T]) = A.1 and
    (forall(x: T, ys: List[T]) { h(List.cons(x, ys)) = f(x) * h(ys) })
    implies h = list_monoid_fold_fn(f)
} by {
    if h(List.nil[T]) = A.1 and
        forall(x: T, ys: List[T]) { h(List.cons(x, ys)) = f(x) * h(ys) } {
        forall(xs: List[T]) {
            list_monoid_fold_unique_at(h, f, xs)
            h(xs) = list_monoid_fold(xs, f)
            list_monoid_fold_fn(f)(xs) = list_monoid_fold(xs, f)
            h(xs) = list_monoid_fold_fn(f)(xs)
        }
        function_extensionality(h, list_monoid_fold_fn(f))
        h = list_monoid_fold_fn(f)
    }
}

/// The evaluator agrees pointwise for functions that agree on every element of the list.
theorem list_monoid_fold_of_pointwise[T, A: Monoid](items: List[T], f: T -> A, g: T -> A) {
    forall(x: T) { items.contains(x) implies f(x) = g(x) } implies
        list_monoid_fold(items, f) = list_monoid_fold(items, g)
} by {
    define p(xs: List[T]) -> Bool {
        forall(x: T) { xs.contains(x) implies f(x) = g(x) } implies
            list_monoid_fold(xs, f) = list_monoid_fold(xs, g)
    }
    p(List.nil[T])
    forall(head: T, tail: List[T]) {
        if p(tail) {
            if forall(x: T) { List.cons(head, tail).contains(x) implies f(x) = g(x) } {
                forall(x: T) {
                    if tail.contains(x) {
                        List.cons(head, tail).contains(x)
                        f(x) = g(x)
                    }
                }
                list_monoid_fold(tail, f) = list_monoid_fold(tail, g)
                List.cons(head, tail).contains(head)
                f(head) = g(head)
                list_monoid_fold(List.cons(head, tail), f) = f(head) * list_monoid_fold(tail, f)
                list_monoid_fold(List.cons(head, tail), g) = g(head) * list_monoid_fold(tail, g)
                f(head) * list_monoid_fold(tail, f) = g(head) * list_monoid_fold(tail, g)
                list_monoid_fold(List.cons(head, tail), f) = list_monoid_fold(List.cons(head, tail), g)
            }
            p(List.cons(head, tail))
        }
    }
    List.induction(function(xs: List[T]) { p(xs) })
    forall(xs: List[T]) { p(xs) }
    p(items)
}

/// If all mapped generators are the identity, the evaluator is the identity.
theorem list_monoid_fold_all_identity[T, A: Monoid](items: List[T], f: T -> A) {
    forall(x: T) { items.contains(x) implies f(x) = A.1 } implies
        list_monoid_fold(items, f) = A.1
} by {
    define p(xs: List[T]) -> Bool {
        forall(x: T) { xs.contains(x) implies f(x) = A.1 } implies
            list_monoid_fold(xs, f) = A.1
    }
    p(List.nil[T])
    forall(head: T, tail: List[T]) {
        if p(tail) {
            if forall(x: T) { List.cons(head, tail).contains(x) implies f(x) = A.1 } {
                forall(x: T) {
                    if tail.contains(x) {
                        List.cons(head, tail).contains(x)
                        f(x) = A.1
                    }
                }
                list_monoid_fold(tail, f) = A.1
                List.cons(head, tail).contains(head)
                f(head) = A.1
                list_monoid_fold(List.cons(head, tail), f) = f(head) * list_monoid_fold(tail, f)
                f(head) * list_monoid_fold(tail, f) = A.1 * A.1
                A.1 * A.1 = A.1
                list_monoid_fold(List.cons(head, tail), f) = A.1
            }
            p(List.cons(head, tail))
        }
    }
    List.induction(function(xs: List[T]) { p(xs) })
    forall(xs: List[T]) { p(xs) }
    p(items)
}

/// Appending one generator multiplies the evaluator on the right by that generator's value.
theorem list_monoid_fold_append_singleton[T, A: Monoid](items: List[T], item: T, f: T -> A) {
    list_monoid_fold(items.append(item), f) = list_monoid_fold(items, f) * f(item)
} by {
    items.append(item) = items + List.singleton(item)
    list_monoid_fold_append(items, List.singleton(item), f)
    list_monoid_fold(items + List.singleton(item), f) =
        list_monoid_fold(items, f) * list_monoid_fold(List.singleton(item), f)
    list_monoid_fold_singleton(item, f)
    list_monoid_fold(List.singleton(item), f) = f(item)
    list_monoid_fold(items.append(item), f) = list_monoid_fold(items, f) * f(item)
}

/// The evaluator of a two-element list is the product of the mapped entries.
theorem list_monoid_fold_pair[T, A: Monoid](first: T, second: T, f: T -> A) {
    list_monoid_fold(List.cons(first, List.singleton(second)), f) = f(first) * f(second)
} by {
    list_monoid_fold_cons(first, List.singleton(second), f)
    list_monoid_fold(List.cons(first, List.singleton(second)), f) =
        f(first) * list_monoid_fold(List.singleton(second), f)
    list_monoid_fold_singleton(second, f)
    list_monoid_fold(List.singleton(second), f) = f(second)
    list_monoid_fold(List.cons(first, List.singleton(second)), f) = f(first) * f(second)
}
