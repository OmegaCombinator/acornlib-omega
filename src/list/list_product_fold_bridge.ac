from list.list_base import List
from list.list_product import product, product_nil, product_cons
from list.list_monoid_fold import list_monoid_fold, list_monoid_fold_nil,
    list_monoid_fold_cons, list_monoid_fold_singleton,
    list_monoid_fold_append_singleton, list_monoid_fold_pair,
    list_monoid_fold_all_identity
from comm_monoid import CommMonoid
from functions import identity_fn

/// The specialized list product is the monoid evaluator with the identity map.
theorem product_eq_list_monoid_fold_identity[A: CommMonoid](items: List[A]) {
    product(items) = list_monoid_fold(items, identity_fn[A])
} by {
    define p(xs: List[A]) -> Bool {
        product(xs) = list_monoid_fold(xs, identity_fn[A])
    }

    product_nil[A]
    product(List.nil[A]) = A.1
    list_monoid_fold_nil[A, A](identity_fn[A])
    list_monoid_fold(List.nil[A], identity_fn[A]) = A.1
    p(List.nil[A])

    forall(head: A, tail: List[A]) {
        if p(tail) {
            product_cons(head, tail)
            product(List.cons(head, tail)) = head * product(tail)
            list_monoid_fold_cons(head, tail, identity_fn[A])
            list_monoid_fold(List.cons(head, tail), identity_fn[A]) =
                identity_fn[A](head) * list_monoid_fold(tail, identity_fn[A])
            identity_fn[A](head) = head
            product(tail) = list_monoid_fold(tail, identity_fn[A])
            head * product(tail) = head * list_monoid_fold(tail, identity_fn[A])
            identity_fn[A](head) * list_monoid_fold(tail, identity_fn[A]) =
                head * list_monoid_fold(tail, identity_fn[A])
            product(List.cons(head, tail)) =
                list_monoid_fold(List.cons(head, tail), identity_fn[A])
            p(List.cons(head, tail))
        }
    }

    List.induction(function(xs: List[A]) { p(xs) })
    forall(xs: List[A]) {
        p(xs)
    }
    p(items)
}

/// The product of a singleton list is its only entry.
theorem product_singleton[A: CommMonoid](x: A) {
    product(List.singleton(x)) = x
} by {
    product_eq_list_monoid_fold_identity(List.singleton(x))
    product(List.singleton(x)) = list_monoid_fold(List.singleton(x), identity_fn[A])
    list_monoid_fold_singleton(x, identity_fn[A])
    list_monoid_fold(List.singleton(x), identity_fn[A]) = identity_fn[A](x)
    identity_fn[A](x) = x
    product(List.singleton(x)) = x
}

/// Appending one element multiplies the product on the right by that element.
theorem product_append_singleton[A: CommMonoid](items: List[A], x: A) {
    product(items.append(x)) = product(items) * x
} by {
    product_eq_list_monoid_fold_identity(items.append(x))
    product_eq_list_monoid_fold_identity(items)
    list_monoid_fold_append_singleton(items, x, identity_fn[A])
    list_monoid_fold(items.append(x), identity_fn[A]) =
        list_monoid_fold(items, identity_fn[A]) * identity_fn[A](x)
    identity_fn[A](x) = x
    product(items) = list_monoid_fold(items, identity_fn[A])
    list_monoid_fold(items, identity_fn[A]) * identity_fn[A](x) = product(items) * x
    product(items.append(x)) = product(items) * x
}

/// The product of a two-element list is the product of the two entries.
theorem product_pair[A: CommMonoid](x: A, y: A) {
    product(List.cons(x, List.singleton(y))) = x * y
} by {
    product_eq_list_monoid_fold_identity(List.cons(x, List.singleton(y)))
    product(List.cons(x, List.singleton(y))) =
        list_monoid_fold(List.cons(x, List.singleton(y)), identity_fn[A])
    list_monoid_fold_pair(x, y, identity_fn[A])
    list_monoid_fold(List.cons(x, List.singleton(y)), identity_fn[A]) =
        identity_fn[A](x) * identity_fn[A](y)
    identity_fn[A](x) = x
    identity_fn[A](y) = y
    identity_fn[A](x) * identity_fn[A](y) = x * y
    product(List.cons(x, List.singleton(y))) = x * y
}

/// If every listed element is the identity, then the product is the identity.
theorem product_all_identity[A: CommMonoid](items: List[A]) {
    forall(x: A) { items.contains(x) implies x = A.1 } implies product(items) = A.1
} by {
    if forall(x: A) { items.contains(x) implies x = A.1 } {
        forall(x: A) {
            if items.contains(x) {
                identity_fn[A](x) = x
                x = A.1
                identity_fn[A](x) = A.1
            }
        }
        list_monoid_fold_all_identity(items, identity_fn[A])
        list_monoid_fold(items, identity_fn[A]) = A.1
        product_eq_list_monoid_fold_identity(items)
        product(items) = list_monoid_fold(items, identity_fn[A])
        product(items) = A.1
    }
}
