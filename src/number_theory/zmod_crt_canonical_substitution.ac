/// A CRT solution substitutes by the canonical class on the left side of `Zmod` addition.
theorem solution_zmod_add_left_crt_canonical(
    system: List[Pair[Nat, Nat]], c: Nat, x: Zmod[system_modulus(system)]
) {
    pairwise_coprime(system_moduli(system))
        and every_modulus_positive(system)
        and satisfies_all(c, system)
        implies zmod_add(system_modulus(system), nat_zmod_mk(system_modulus(system), c), x) =
            zmod_add(system_modulus(system), crt_canonical_zmod(system), x)
} by {
    if pairwise_coprime(system_moduli(system))
        and every_modulus_positive(system)
        and satisfies_all(c, system) {
        solution_zmod_eq_crt_canonical_zmod(system, c)
        nat_zmod_mk(system_modulus(system), c) = crt_canonical_zmod(system)
        zmod_eq_crt_canonical_add_left(system, c, x)
        zmod_add(system_modulus(system), nat_zmod_mk(system_modulus(system), c), x) =
            zmod_add(system_modulus(system), crt_canonical_zmod(system), x)
    }
}

