/// Substitution consumers for canonical CRT classes in `Zmod` form.
///
/// These lemmas keep the existing list-of-pairs CRT representation and provide
/// small, direct substitution tools for explicit `Zmod` addition and
/// multiplication expressions involving the canonical CRT class.

from number_theory.congruence import Nat
from zmod import Zmod, zmod_add, zmod_mul
from number_theory.zmod_bridge import nat_zmod_mk
from number_theory.zmod_crt_canonical_bridge import crt_canonical_zmod,
    solution_zmod_eq_crt_canonical_zmod
from number_theory.crt_list import satisfies_all, system_moduli, system_modulus,
    every_modulus_positive
from number_theory.pairwise_coprime import pairwise_coprime
from list import List
from pair import Pair

/// Equality with the canonical CRT class substitutes into the left side of `Zmod` addition.
theorem zmod_eq_crt_canonical_add_left(
    system: List[Pair[Nat, Nat]], c: Nat, x: Zmod[system_modulus(system)]
) {
    nat_zmod_mk(system_modulus(system), c) = crt_canonical_zmod(system) implies
        zmod_add(system_modulus(system), nat_zmod_mk(system_modulus(system), c), x) =
            zmod_add(system_modulus(system), crt_canonical_zmod(system), x)
} by {
    if nat_zmod_mk(system_modulus(system), c) = crt_canonical_zmod(system) {
        zmod_add(system_modulus(system), nat_zmod_mk(system_modulus(system), c), x) =
            zmod_add(system_modulus(system), crt_canonical_zmod(system), x)
    }
}

