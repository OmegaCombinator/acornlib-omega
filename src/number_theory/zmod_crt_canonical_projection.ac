/// The canonical cons solution has the tail canonical normalized representative.
theorem crt_canonical_cons_normalized_tail_eq_crt_canonical_tail(
    head: Pair[Nat, Nat], tail: List[Pair[Nat, Nat]]
) {
    pairwise_coprime(system_moduli(List.cons(head, tail)))
        and every_modulus_positive(List.cons(head, tail))
        implies crt_canonical_solution(List.cons(head, tail)).mod(system_modulus(tail)) =
            crt_canonical_solution(tail)
} by {
    if pairwise_coprime(system_moduli(List.cons(head, tail)))
        and every_modulus_positive(List.cons(head, tail)) {
        crt_canonical_cons_tail_satisfies(head, tail)
        satisfies_all(crt_canonical_solution(List.cons(head, tail)), tail)
        system_moduli(List.cons(head, tail)) = List.cons(head.first, system_moduli(tail))
        pairwise_coprime(List.cons(head.first, system_moduli(tail)))
        pairwise_coprime_cons_imp(head.first, system_moduli(tail))
        pairwise_coprime(system_moduli(tail))
        every_modulus_positive_cons_imp(head, tail)
        every_modulus_positive(tail)
        solution_normalized_representative_eq_canonical(tail, crt_canonical_solution(List.cons(head, tail)))
        crt_canonical_solution(List.cons(head, tail)).mod(system_modulus(tail)) =
            crt_canonical_solution(tail)
    }
}

/// The canonical cons solution has the tail canonical normalized `Zmod` class.
