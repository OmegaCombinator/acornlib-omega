/// Pointwise betweenness on the left domain restricts to its intersection with the right domain.
theorem function_between_on_intersection_left[Domain, Value: PartialOrder](
    left: Set[Domain], right: Set[Domain], lower: Domain -> Value,
    middle: Domain -> Value, upper: Domain -> Value
