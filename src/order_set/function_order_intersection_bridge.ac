theorem function_lte_on_intersection_right[Domain, Value: PartialOrder](
    left: Set[Domain], right: Set[Domain], lower: Domain -> Value, upper: Domain -> Value
) {
    function_lte_on(right, lower, upper) implies function_lte_on(left.intersection(right), lower, upper)
