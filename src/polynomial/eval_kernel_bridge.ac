from semiring import Semiring
from ring import Ring
from comm_ring import CommRing
from polynomial.base import Polynomial
from polynomial.mul import polynomial_mul
from polynomial.eval_hom import polynomial_eval_at, polynomial_eval_at_zero,
    polynomial_eval_at_add, polynomial_eval_at_neg, polynomial_eval_at_sub,
    polynomial_eval_at_mul

/// A polynomial vanishes at `x` when its evaluation at `x` is zero.
define polynomial_vanishes_at[R: Semiring](x: R, p: Polynomial[R]) -> Bool {
    polynomial_eval_at(x, p) = R.0
}

/// The zero polynomial vanishes at every point.
theorem polynomial_vanishes_at_zero[R: Semiring](x: R) {
    polynomial_vanishes_at(x, Polynomial[R].zero)
} by {
    polynomial_eval_at_zero(x)
    polynomial_eval_at(x, Polynomial[R].zero) = R.0
    polynomial_vanishes_at(x, Polynomial[R].zero)
}

/// The sum of two polynomials vanishing at `x` also vanishes at `x`.
theorem polynomial_vanishes_at_add[R: Semiring](x: R, p: Polynomial[R], q: Polynomial[R]) {
    polynomial_vanishes_at(x, p) and polynomial_vanishes_at(x, q) implies
    polynomial_vanishes_at(x, p + q)
} by {
    if polynomial_vanishes_at(x, p) and polynomial_vanishes_at(x, q) {
        polynomial_vanishes_at(x, p) = (polynomial_eval_at(x, p) = R.0)
        polynomial_vanishes_at(x, q) = (polynomial_eval_at(x, q) = R.0)
        polynomial_eval_at(x, p) = R.0
        polynomial_eval_at(x, q) = R.0
        polynomial_eval_at_add(x, p, q)
        polynomial_eval_at(x, p + q) = polynomial_eval_at(x, p) + polynomial_eval_at(x, q)
        polynomial_eval_at(x, p + q) = R.0 + R.0
        R.0 + R.0 = R.0
        polynomial_eval_at(x, p + q) = R.0
        polynomial_vanishes_at(x, p + q)
    }
}

/// The additive inverse of a polynomial vanishing at `x` also vanishes at `x`.
theorem polynomial_vanishes_at_neg[R: Ring](x: R, p: Polynomial[R]) {
    polynomial_vanishes_at(x, p) implies polynomial_vanishes_at(x, p.neg)
} by {
    if polynomial_vanishes_at(x, p) {
        polynomial_vanishes_at(x, p) = (polynomial_eval_at(x, p) = R.0)
        polynomial_eval_at(x, p) = R.0
        polynomial_eval_at_neg(x, p)
        polynomial_eval_at(x, p.neg) = -polynomial_eval_at(x, p)
        polynomial_eval_at(x, p.neg) = -R.0
        R.0 + -R.0 = R.0
        R.0 + -R.0 = -R.0
        -R.0 = R.0
        polynomial_eval_at(x, p.neg) = R.0
        polynomial_vanishes_at(x, p.neg)
    }
}

/// The difference of two polynomials vanishing at `x` also vanishes at `x`.
theorem polynomial_vanishes_at_sub[R: Ring](x: R, p: Polynomial[R], q: Polynomial[R]) {
    polynomial_vanishes_at(x, p) and polynomial_vanishes_at(x, q) implies
    polynomial_vanishes_at(x, p.sub(q))
} by {
    if polynomial_vanishes_at(x, p) and polynomial_vanishes_at(x, q) {
        polynomial_vanishes_at(x, p) = (polynomial_eval_at(x, p) = R.0)
        polynomial_vanishes_at(x, q) = (polynomial_eval_at(x, q) = R.0)
        polynomial_eval_at(x, p) = R.0
        polynomial_eval_at(x, q) = R.0
        polynomial_eval_at_sub(x, p, q)
        polynomial_eval_at(x, p.sub(q)) = polynomial_eval_at(x, p) - polynomial_eval_at(x, q)
        polynomial_eval_at(x, p.sub(q)) = R.0 - R.0
        R.0 - R.0 = R.0 + -R.0
        R.0 + -R.0 = R.0
        polynomial_eval_at(x, p.sub(q)) = R.0
        polynomial_vanishes_at(x, p.sub(q))
    }
}

/// If the left factor vanishes at `x`, then the product vanishes at `x`.
theorem polynomial_vanishes_at_mul_left[R: CommRing](x: R, p: Polynomial[R], q: Polynomial[R]) {
    polynomial_vanishes_at(x, p) implies polynomial_vanishes_at(x, polynomial_mul(p, q))
} by {
    if polynomial_vanishes_at(x, p) {
        polynomial_vanishes_at(x, p) = (polynomial_eval_at(x, p) = R.0)
        polynomial_eval_at(x, p) = R.0
        polynomial_eval_at_mul(x, p, q)
        polynomial_eval_at(x, polynomial_mul(p, q)) = polynomial_eval_at(x, p) * polynomial_eval_at(x, q)
        polynomial_eval_at(x, polynomial_mul(p, q)) = R.0 * polynomial_eval_at(x, q)
        R.0 * polynomial_eval_at(x, q) = R.0
        polynomial_eval_at(x, polynomial_mul(p, q)) = R.0
        polynomial_vanishes_at(x, polynomial_mul(p, q))
    }
}

/// If the right factor vanishes at `x`, then the product vanishes at `x`.
theorem polynomial_vanishes_at_mul_right[R: CommRing](x: R, p: Polynomial[R], q: Polynomial[R]) {
    polynomial_vanishes_at(x, q) implies polynomial_vanishes_at(x, polynomial_mul(p, q))
} by {
    if polynomial_vanishes_at(x, q) {
        polynomial_vanishes_at(x, q) = (polynomial_eval_at(x, q) = R.0)
        polynomial_eval_at(x, q) = R.0
        polynomial_eval_at_mul(x, p, q)
        polynomial_eval_at(x, polynomial_mul(p, q)) = polynomial_eval_at(x, p) * polynomial_eval_at(x, q)
        polynomial_eval_at(x, polynomial_mul(p, q)) = polynomial_eval_at(x, p) * R.0
        polynomial_eval_at(x, p) * R.0 = R.0
        polynomial_eval_at(x, polynomial_mul(p, q)) = R.0
        polynomial_vanishes_at(x, polynomial_mul(p, q))
    }
}
